        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />

    <!-- Hanger crossbar — solid line at bottom of arc -->
    <path
        android:pathData="M26,46 L82,46"
        android:strokeColor="#c084fc"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- ── Body of garment — stylized shirt silhouette ── -->
    <path
        android:pathData="
          M30,46
          L24,58
          L36,62
          L36,86
          L72,86
          L72,62
          L84,58
          L78,46
