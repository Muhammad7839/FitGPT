<?xml version="1.0" encoding="utf-8"?>
<!--
  FitGPT adaptive icon foreground.
  Design: stylized clothing hanger with "F" lettermark — clean fashion brand mark.
  Viewport 108×108. Safe zone: 72×72 centered (18dp inset each side).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
