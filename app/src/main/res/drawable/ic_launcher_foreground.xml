        android:fillAlpha="0.92" />

    <!-- Collar cutout — V-neck -->
    <path
        android:pathData="M46,46 L54,60 L62,46 Z"
        android:fillColor="#1a1a2e" />

    <!-- Subtle sleeve shading -->
    <path
        android:pathData="M30,46 L24,58 L36,62 L36,50 Z"
        android:fillColor="#9333ea"
        android:fillAlpha="0.6" />
    <path
        android:pathData="M78,46 L84,58 L72,62 L72,50 Z"
        android:fillColor="#9333ea"
        android:fillAlpha="0.6" />

    <!-- Small "G" initial wordmark below collar — pill accent -->
    <path
        android:pathData="M49,70 A5,5 0 0 1 59,70 A5,5 0 0 1 49,70 Z"
        android:fillColor="#ffffff"
        android:fillAlpha="0.15" />

</vector>
