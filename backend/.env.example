# Copy this file to backend/.env for local development.
ENVIRONMENT=development
SECRET_KEY=change-me-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
RESET_TOKEN_EXPIRE_MINUTES=30
EXPOSE_RESET_TOKEN_IN_RESPONSE=true
MAX_UPLOAD_IMAGE_BYTES=5242880
OPENWEATHER_API_KEY=your_openweather_key
GOOGLE_CLIENT_ID=your_google_web_client_id
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
# Vision model for receipt OCR (leave blank to disable). See https://console.groq.com/docs/models
GROQ_VISION_MODEL=
AI_TIMEOUT_SECONDS=12
AI_MAX_TOKENS=450
AI_TEMPERATURE=0.4
